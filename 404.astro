---
import {
  ArrowRight, BadgeDollarSign, Check, ChevronDown, Clock3, Droplets, Flame,
  Fuel, House, Image as ImageIcon, MapPin, Menu, MessageCircle, Phone,
  Route, Search, ShieldCheck, Siren, Workflow, Wrench, X
} from '@lucide/astro';

interface Props { name: string; size?: number; class?: string; strokeWidth?: number; }
const { name, size = 22, class: className = '', strokeWidth = 1.5 } = Astro.props;
const icons: Record<string, any> = {
  'arrow-right': ArrowRight,
  'badge-dollar-sign': BadgeDollarSign,
  check: Check,
  'chevron-down': ChevronDown,
  clock: Clock3,
  droplets: Droplets,
  flame: Flame,
  fuel: Fuel,
  home: House,
  image: ImageIcon,
  'map-pin': MapPin,
  menu: Menu,
  message: MessageCircle,
  phone: Phone,
  route: Route,
  search: Search,
  'shield-check': ShieldCheck,
  siren: Siren,
  workflow: Workflow,
  wrench: Wrench,
  x: X
};
const Component = icons[name] || Wrench;
---
<Component size={size} stroke-width={strokeWidth} class={className} aria-hidden="true" />
